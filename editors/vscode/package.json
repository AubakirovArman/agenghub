{
  "name": "agenthub-vscode",
  "displayName": "AgentHub",
  "description": "Inspect AgentHub transactions, memory, AgentSpecs, and DAGs from VS Code.",
  "version": "0.1.0",
  "publisher": "agenthub",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:agenthub.refresh",
    "onCommand:agenthub.openLatestReport",
    "onCommand:agenthub.openMemory",
    "onCommand:agenthub.createSpecFromPrompt",
    "onCommand:agenthub.openDag",
    "onCommand:agenthub.openApprovals",
    "onCommand:agenthub.approveSpec"
  ],
  "main": "./extension.js",
  "scripts": {
    "test": "node test/approvals.test.js",
    "check": "node --check extension.js && node --check src/commands.js && node --check src/approvals.js && node --check src/approvalProvider.js && node --check src/specs.js && node --check src/specProvider.js && node --check src/cli.js && node --check src/dagView.js && node --check src/providers.js && node --check src/utils.js && npm test"
  },
  "contributes": {
    "configuration": {
      "title": "AgentHub",
      "properties": {
        "agenthub.executable": {
          "type": "string",
          "default": "agenthub",
          "description": "AgentHub CLI executable used by VS Code commands."
        }
      }
    },
    "commands": [
      {
        "command": "agenthub.refresh",
        "title": "AgentHub: Refresh"
      },
      {
        "command": "agenthub.openLatestReport",
        "title": "AgentHub: Open Latest Transaction Report"
      },
      {
        "command": "agenthub.openMemory",
        "title": "AgentHub: Open Memory"
      },
      {
        "command": "agenthub.createSpecFromPrompt",
        "title": "AgentHub: Create AgentSpec From Prompt"
      },
      {
        "command": "agenthub.openDag",
        "title": "AgentHub: Open Latest DAG"
      },
      {
        "command": "agenthub.openApprovals",
        "title": "AgentHub: Open Approvals"
      },
      {
        "command": "agenthub.approveSpec",
        "title": "AgentHub: Approve AgentSpec"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agenthub",
          "title": "AgentHub",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agenthub": [
        {
          "id": "agenthub.transactions",
          "name": "Transactions"
        },
        {
          "id": "agenthub.memory",
          "name": "Memory"
        },
        {
          "id": "agenthub.specs",
          "name": "AgentSpecs"
        },
        {
          "id": "agenthub.approvals",
          "name": "Approvals"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "agenthub.refresh",
          "when": "view =~ /agenthub\\./",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "agenthub.approveSpec",
          "when": "view == agenthub.approvals && viewItem == agenthubApprovalSpec",
          "group": "inline"
        }
      ]
    },
    "jsonValidation": [
      {
        "fileMatch": [
          "/agenthub*.yaml",
          "/agenthub*.yml",
          "/task*.yaml",
          "/task*.yml",
          "/examples/*task.yaml"
        ],
        "url": "./schemas/agent-spec.schema.json"
      }
    ]
  }
}
